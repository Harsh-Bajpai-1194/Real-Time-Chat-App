{
  "name": "real-time-chat-app",
  "version": "1.0.0",
  "description": "A simple real-time chat application with Node.js, Express, and Socket.IO.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "pnpm --prefix client start",
    "dev": "concurrently \"pnpm run server\" \"pnpm run client\""
  },
  "license": "MIT",
  "dependencies": {
    "bad-words": "3.0.4",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.5.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  }
}
